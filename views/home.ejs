<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Crowded Fashion | Minimalist Elegance</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary: #1a1a1a;
      --accent: #f97316;
      --bg: #fcfcfc;
      --white: #ffffff;
      --text-muted: #64748b;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: var(--bg);
      color: var(--primary);
      overflow-x: hidden;
    }

    /* ── NAV BAR ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 10%;
      position: fixed;
      width: 100%;
      top: 0;
      z-index: 1000;
      background: rgba(252, 252, 252, 0.8);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      text-decoration: none;
      color: var(--primary);
      letter-spacing: -0.5px;
    }

    .nav-links {
      display: flex;
      gap: 40px;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--primary);
      font-weight: 500;
      font-size: 0.9rem;
      transition: color 0.3s;
    }

    .nav-links a:hover { color: var(--accent); }

    /* ── HERO SECTION ── */
    .hero {
      height: 100vh;
      display: flex;
      align-items: center;
      padding: 0 10%;
      gap: 50px;
      margin-top: 40px;
    }

    .hero-content {
      flex: 1;
      max-width: 600px;
    }

    .hero-tagline {
      color: var(--accent);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.8rem;
      margin-bottom: 20px;
      display: block;
    }

    .hero-content h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 8vw, 5rem);
      line-height: 1.1;
      margin-bottom: 25px;
    }

    .hero-content p {
      color: var(--text-muted);
      font-size: 1.1rem;
      line-height: 1.8;
      margin-bottom: 40px;
    }

    .cta-group {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .btn-primary {
      background: var(--primary);
      color: var(--white);
      padding: 18px 35px;
      text-decoration: none;
      border-radius: 50px;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      background: #333;
    }

    /* ── HERO IMAGE ── */
    .hero-image-container {
      flex: 1;
      position: relative;
      height: 80vh;
      border-radius: 30px;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    }

    .hero-image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 1s;
    }

    .hero-image-container:hover img {
      transform: scale(1.05);
    }

    /* ── DECORATIVE ELEMENTS ── */
    .circle-decoration {
      position: absolute;
      width: 400px;
      height: 400px;
      background: linear-gradient(135deg, #fff5ed 0%, #ffffff 100%);
      border-radius: 50%;
      z-index: -1;
      top: 10%;
      right: 5%;
    }

    /* ── MOBILE RESPONSIVENESS ── */
    @media (max-width: 968px) {
      .hero {
        flex-direction: column-reverse;
        text-align: center;
        padding-top: 120px;
        height: auto;
      }
      .hero-image-container {
        width: 100%;
        height: 50vh;
      }
      .cta-group { justify-content: center; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

  <div class="circle-decoration"></div>

  <nav>
    <a href="/" class="logo">Crowded Fashion.</a>
    <div class="nav-links">
      <a href="/home">Home</a>
      <a href="/store">Collection</a>
      <a href="/orders">Orders</a>
      <a href="/cart">Cart</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <span class="hero-tagline">New Season Arrivals</span>
      <h1>Elegance is an <br><i>Attitude</i>.</h1>
      <p>Discover our curated collection of minimalist essentials designed for the modern individual who values quality and timeless style.</p>
      
      <div class="cta-group">
        <a href="/store" class="btn-primary">Shop Collection</a>
        <a href="/store?category=New" style="text-decoration:none; color: var(--primary); font-weight: 600; font-size: 0.9rem; border-bottom: 2px solid var(--accent)">View Lookbook</a>
      </div>
    </div>

    <div class="hero-image-container">
      <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=2070&auto=format&fit=crop" alt="Fashion Model">
    </div>
  </section>

</body>
</html>