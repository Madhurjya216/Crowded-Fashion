<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Orders | Crowded Fashion</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg-color: #fcfcf9;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --accent: #f97316;
            --white: #ffffff;
            --border: #e2e8f0;
            --success: #10b981;
            --pending: #f59e0b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        /* --- Navigation --- */
        nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2.5rem;
        background: rgba(245, 244, 240, 0.95);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      }

      .nav-links {
        display: flex;
        gap: 40px;
      }

      .nav-brand-child {
        font:
          15px "Nunito",
          sans-serif;
        text-decoration: none;
      }

      /* Hide Hamburger on Desktop */
      .menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-main);
        padding: 10px;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        border-radius: 8px;
        outline: none;
        -webkit-tap-highlight-color: transparent; /* Removes blue flash on mobile tap */
      }

      .menu-toggle:hover {
        background: rgba(0, 0, 0, 0.05); /* Visual feedback when hovering */
      }

      .menu-toggle svg {
        width: 28px;
        height: 28px;
        pointer-events: none; /* Ensures the click registers on the button, not the path */
      }

        .nav-brand {
            font-family: "Libre Baskerville", serif;
            font-size: 1.2rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--text-main);
        }

        /* --- Container --- */
        .container {
            max-width: 800px;
            margin: 60px auto;
            padding: 0 20px;
        }

        h2 {
            font-family: "Libre Baskerville", serif;
            font-size: 2.5rem;
            margin-bottom: 40px;
            text-align: center;
        }

        /* --- Order Card --- */
        .order-card {
            background: var(--white);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
            border: 1px solid var(--border);
            transition: transform 0.3s ease;
        }

        .order-card:hover {
            transform: translateY(-5px);
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f1f5f9;
        }

        .order-meta p {
            margin: 0;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .order-total {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-main);
            margin-top: 5px;
        }

        /* Status Badges */
        .status-badge {
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-completed { background: #d1fae5; color: #065f46; }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-shipped { background: #e0f2fe; color: #075985; }

        /* --- Address Section --- */
        .address-box {
            margin-bottom: 25px;
        }

        .label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
            display: block;
            margin-bottom: 8px;
        }

        .address-text {
            font-size: 0.95rem;
            color: var(--text-main);
        }

        /* --- Items List --- */
        .items-section {
            background: #f8fafc;
            border-radius: 12px;
            padding: 20px;
        }

        .item-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 0.95rem;
        }

        .item-row:not(:last-child) {
            border-bottom: 1px dashed #e2e8f0;
        }

        .item-name {
            font-weight: 600;
        }

        .item-qty {
            color: var(--text-muted);
        }

        /* Empty State */
        .empty-orders {
            text-align: center;
            padding: 60px;
            color: var(--text-muted);
        }

        @media (max-width: 600px) {
            .order-header {
                flex-direction: column;
                gap: 15px;
            }
        }

        /* --- Responsive Menu (Trigger at 550px) --- */
      @media (max-width: 550px) {
        nav {
          padding: 1rem 1.5rem;
        }

        @media (max-width: 550px) {
          .menu-toggle {
            display: flex; /* Now it only appears on small screens */
          }

          .nav-links {
            display: none; /* Hide standard links */
            flex-direction: column;
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: rgba(245, 244, 240, 0.98);
            padding: 20px 0;
            text-align: center;
            gap: 20px;
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.05);
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
          }

          .nav-links.active {
            display: flex; /* Show links when toggled */
          }
        }
      }
    </style>
</head>
<body>

    <nav>
      <a href="/store" class="nav-brand">Crowded Fashion</a>

      <button
        class="menu-toggle"
        id="menu-toggle"
        aria-label="Toggle navigation"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <div class="nav-links" id="nav-links">
        <a href="/home" class="nav-brand-child">Home</a>
        <a href="/cart" class="nav-brand-child">Cart</a>
      </div>
    </nav>

    <div class="container">
        <h2>Your Orders</h2>

        <% if (orders.length > 0) { %>
            <% orders.forEach(order => { %>
                <div class="order-card">
                    <div class="order-header">
                        <div class="order-meta">
                            <p>Order Summary</p>
                            <div class="order-total">₹<%= order.totalAmount %></div> 
                        </div>
                        <span class="status-badge status-<%= order.status.toLowerCase() %>">
                            <%= order.status %> 
                        </span>
                    </div>

                    <div class="address-box">
                        <span class="label">Shipping Address</span>
                        <div class="address-text"><%= order.address %></div> 
                    </div>

                    <div class="items-section">
                        <span class="label">Items Purchased</span>
                        <% order.items.forEach(item => { %>
                            <div class="item-row">
                                <span class="item-name"><%= item.name %></span> 
                                <span class="item-qty">x<%= item.quantity %></span> 
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %> 
        <% } else { %>
            <div class="empty-orders">
                <p>You haven't placed any orders yet.</p>
                <a href="/store" style="color: var(--accent); font-weight: 600;">Start Shopping</a>
            </div>
        <% } %>
    </div>



    <script>
      async function addToCart(id) {
        try {
          const res = await fetch(`/cart/add/${id}`, {
            method: "POST",
          });
          const data = await res.json();

          if (data.success) {
            alert("Added to cart successfully!");
          } else {
            alert("Could not add to cart");
          }
        } catch (err) {
          console.error(err);
          alert("Network error");
        }
      }

      const menuToggle = document.getElementById("menu-toggle");
      const navLinks = document.getElementById("nav-links");

      menuToggle.addEventListener("click", () => {
        // This toggles the 'active' class which controls visibility in CSS
        navLinks.classList.toggle("active");

        // Optional: Change hamburger icon to an 'X' when open
        const isOpened = navLinks.classList.contains("active");
        menuToggle.innerHTML = isOpened
          ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>'
          : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>';
      });

      // Close menu when clicking outside
      document.addEventListener("click", (e) => {
        if (!menuToggle.contains(e.target) && !navLinks.contains(e.target)) {
          navLinks.classList.remove("active");
        }
      });
    </script>


<%- include('footer') %>
</body>
</html>