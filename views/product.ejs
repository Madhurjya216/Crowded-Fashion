<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Store</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300..700;1,300..700&family=Crimson+Pro:ital,wght@0,200..900;1,200..900&family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Dongle&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Macondo&family=Marcellus&family=Megrim&family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --accent: #f97316; /* Modern Orange */
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        }

        /* ── NAV BAR ── */
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2.5rem;
        background: rgba(245, 244, 240, 0.95);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      }

      .nav-links {
        display: flex;
        gap: 40px;
      }

      /* Hide Hamburger on Desktop */
      .menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-main);
        padding: 10px;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        border-radius: 8px;
        outline: none;
        -webkit-tap-highlight-color: transparent; /* Removes blue flash on mobile tap */
      }

      .menu-toggle:hover {
        background: rgba(0, 0, 0, 0.05); /* Visual feedback when hovering */
      }

      .menu-toggle svg {
        width: 28px;
        height: 28px;
        pointer-events: none; /* Ensures the click registers on the button, not the path */
      }

    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: var(--accent);
      letter-spacing: .02em;
      text-decoration: none;
    }

    .nav-brand-child{
        font: 18px;
        text-decoration: none;;
        font-family: "Nunito", sans-serif;
        transition: .2s ease;
    }

    .nav-brand-child:hover{
        color: orangered
    }

    .nav-back {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .875rem;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-back:hover { color: var(--accent); }
    .nav-back svg { width:16px; height:16px; }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 40px 20px; 
            background: #f5f5f1;
        }

        h1 { 
            text-align: center; 
            margin-bottom: 40px; 
            font-family: "Libre Baskerville", serif; 
            font-weight: 700;
            font-size: 2.5rem;
        }

        /* Modern Navigation Pills */
        .nav { 
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 50px; 
            flex-wrap: wrap;
        }

        .category-btn { 
            padding: 10px 24px; 
            text-decoration: none; 
            color: var(--text-main); 
            background: var(--card-bg);
            border: 1px solid #e2e8f0; 
            border-radius: 50px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .category-btn:hover, .category-btn.active {
            background: var(--text-main);
            color: white; 
            border-color: var(--text-main);
            box-shadow: var(--shadow);
        }

        /* Product Grid */
        .products {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
            gap: 30px; 
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Card Design */
        .card {
            background: var(--card-bg);
            border-radius: 16px; 
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease; 
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card:hover {
            transform: translateY(-8px); 
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        }

        .image-container {
            position: relative;
            width: 100%;
            height: 220px;
            overflow: hidden;
        }

        img {
            width: 100%;
            height: 100%;
            object-fit: cover; 
        }

        .card-content {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .card h3 {
            margin: 0 0 8px 0;
            font-size: 1.25rem;
        }

        .card p {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 15px;
        }

        .price-row {
            margin-top: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 15px;
            border-top: 1px solid #f1f5f9;
        }

        .price {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-main);
        }

        /* Modern Add to Cart Button */
        .cart-btn {
            background: var(--accent); 
            color: white; 
            border: none;
            padding: 10px 18px; 
            border-radius: 10px; 
            font-weight: 600;
            cursor: pointer; 
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cart-btn:hover {
            background: #ea580c;
        }

        .hr{
           color: red
        }

        @media (max-width: 550px) {
        nav {
          padding: 1rem 1.5rem;
        }

        @media (max-width: 550px) {
          .menu-toggle {
            display: flex; /* Now it only appears on small screens */
          }

          .nav-links {
            display: none; /* Hide standard links */
            flex-direction: column;
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: rgba(245, 244, 240, 0.98);
            padding: 20px 0;
            text-align: center;
            gap: 20px;
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.05);
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
          }

          .nav-links.active {
            display: flex; /* Show links when toggled */
          }
        }
      }
    </style>
</head>
<body>

   <nav>
      <a href="/store" class="nav-brand">Crowded Fashion</a>

      <button
        class="menu-toggle"
        id="menu-toggle"
        aria-label="Toggle navigation"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <div class="nav-links" id="nav-links">
        <a href="/home" class="nav-brand-child">Home</a>
        <a href="/cart" class="nav-brand-child">Cart</a>
      </div>
    </nav>
<hr class="hr">
<h1>🛒 Deal of the day</h1>

<div class="nav">
  <% categories.forEach(cat => { %>
    <a href="/store?category=<%= cat %>" 
       class="category-btn <%= selectedCategory === cat ? 'active' : '' %>">
      <%= cat %>
    </a>
  <% }) %>
</div>

<div class="products">
  <% products.forEach(p => { %>
    <div class="card">
      <a href="/store/<%= p.id %>" style="text-decoration:none; color:inherit;">
        <div class="image-container">
          <img src="<%= p.image %>" alt="<%= p.name %>" />
        </div>
        <div class="card-content">
          <h3><%= p.name %></h3>
          <p><%= p.description.substring(0, 80) %>...</p>
      </a>
          <div class="price-row">
            <span class="price">₹<%= p.price %></span>
            <button class="cart-btn" onclick="addToCart('<%= p.id %>')">
              <span>+</span> Cart
            </button>
          </div>
        </div>
    </div>
  <% }) %>
</div>

<script>
      async function addToCart(id) {
        try {
          const res = await fetch(`/cart/add/${id}`, {
            method: "POST",
          });
          const data = await res.json(); 

          if (data.success) { 
            alert("Added to cart"); 
          } else {
            alert("Failed to add product");
          }
        } catch (err) {
          console.error(err); 
          alert("Error connecting to server"); 
        }
      }

       const menuToggle = document.getElementById("menu-toggle");
      const navLinks = document.getElementById("nav-links");

      menuToggle.addEventListener("click", () => {
        // This toggles the 'active' class which controls visibility in CSS
        navLinks.classList.toggle("active");

        // Optional: Change hamburger icon to an 'X' when open
        const isOpened = navLinks.classList.contains("active");
        menuToggle.innerHTML = isOpened
          ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>'
          : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>';
      });

      // Close menu when clicking outside
      document.addEventListener("click", (e) => {
        if (!menuToggle.contains(e.target) && !navLinks.contains(e.target)) {
          navLinks.classList.remove("active");
        }
      });
</script>


<%- include('footer') %>
</body>
</html>